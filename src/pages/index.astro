---
import Minimal from "../layouts/Minimal.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import Background from "../components/Background.astro";
import { getCollection } from "astro:content";

const allWork = (await getCollection("work")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allWriting = (await getCollection("writing")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredWork = [
    allWork.find((p) => p.id === "proompting-party"),
    allWork.find((p) => p.id === "auxin"),
].filter(Boolean) as Array<(typeof allWork)[number]>;

const featuredWriting = [
    allWriting.find((p) => p.id === "contra-familiarity"),
    allWriting.find((p) => p.id === "event-sourcing-at-auxin"),
    allWriting.find((p) => p.id === "proompting-party-architecture"),
].filter(Boolean) as Array<(typeof allWriting)[number]>;
---

<Minimal title={SITE_TITLE} description={SITE_DESCRIPTION}>
    <div
        class="mx-auto flex flex-col min-h-screen max-w-[48rem] justify-center px-6 py-16 md:px-8"
    >
        <!-- Hero -->
        <div class="hero mb-16 text-center p-10 md:p-14">
            <header class="mb-10">
                <h1
                    transition:name="title"
                    transition:animate="slide"
                    class="hero-title mb-6 text-7xl leading-[1.05] font-bold md:text-5xl"
                >
                    Tim Willebrands
                </h1>
                <p class="hero-role mb-6">
                    Software Craftsman & Technical Leader
                </p>
                <p class="hero-bio mx-auto max-w-xl">
                    I'm a builder at heart, driven by the quiet joy of taking a
                    complex, messy problem and distilling it down to a clean,
                    maintainable solution. I do my best work with a high degree
                    of autonomy, taking full ownership of a product from the
                    initial spark of an idea to its life in production.
                    Elevating the team's technical bar through sharing the
                    craft.
                    <br /><br />
                    Whether it's code, a loaf of bread, or a game prototype with friends,
                    I believe in the craft of making things well. My goal is to build
                    software that is not just robust, but a pleasure to use and a
                    pleasure for other engineers to work on.
                </p>
            </header>

            <!-- Social Links -->
            <div class="social-row mb-10">
                <a
                    href="mailto:mail@timwillebrands.nl?subject=Let%27s%20build%20something%20together%21&body=Hi%20Tim%2C%0A%0AI%20love%20your%20approach%20to%20building%20systems%20and%20crafting%20things.%20I%27m%20reaching%20out%20because..."
                    class="social-link"
                >
                    <svg
                        width="18"
                        height="18"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                    >
                        <path
                            d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"
                        ></path>
                        <path
                            d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"
                        ></path>
                    </svg>
                    Email
                </a>
                <a
                    href="https://www.linkedin.com/in/tim-willebrands-191b12a2"
                    class="social-link"
                    target="_blank"
                    rel="noopener"
                >
                    <svg
                        width="18"
                        height="18"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                    >
                        <path
                            d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"
                        ></path>
                    </svg>
                    LinkedIn
                </a>
                <a
                    href="https://github.com/timwillebrands"
                    class="social-link"
                    target="_blank"
                    rel="noopener"
                >
                    <svg
                        width="18"
                        height="18"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                            clip-rule="evenodd"></path>
                    </svg>
                    GitHub
                </a>
                <a
                    href="https://bsky.app/profile/tim0theus.bsky.social"
                    class="social-link"
                    target="_blank"
                    rel="noopener"
                >
                    <svg
                        width="18"
                        height="18"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                    >
                        <path
                            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                        ></path>
                    </svg>
                    Bluesky
                </a>
            </div>

            <!-- CTAs -->
            <nav class="flex flex-wrap justify-center gap-4">
                <a href="/work" class="cta cta-primary">View My Work</a>
                <a href="/writing" class="cta cta-secondary">Read My Writing</a>
            </nav>
        </div>

        <!-- Featured Content -->
        <section
            aria-labelledby="featured-work"
            class="featured-section grid grid-cols-1 gap-12 md:grid-cols-2"
        >
            <div>
                <h3
                    id="featured-work"
                    class="featured-heading"
                >
                    Selected Work
                </h3>
                <ul class="featured-list">
                    {
                        featuredWork.map((post) => (
                            <li>
                                <a
                                    href={`/work/${post.id}/`}
                                    class="featured-link"
                                >
                                    <span class="featured-title">
                                        {post.data.title}
                                    </span>
                                    <span class="featured-summary">
                                        {post.data.summary}
                                    </span>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
            <div>
                <h3
                    id="featured-writing"
                    class="featured-heading"
                >
                    Recent Thinking
                </h3>
                <ul class="featured-list">
                    {
                        featuredWriting.map((post) => (
                            <li>
                                <a
                                    href={`/writing/${post.id}/`}
                                    class="featured-link"
                                >
                                    <span class="featured-title">
                                        {post.data.title}
                                    </span>
                                    <span class="featured-summary">
                                        {post.data.summary}
                                    </span>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </section>

        <Background startColor="#8af0e0" endColor="#c6dbff" />
    </div>
</Minimal>

<style>
    .hero {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
    }

    .hero-title {
        letter-spacing: -0.03em;
    }

    .hero-role {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--ink-soft);
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .hero-bio {
        font-size: 1.1rem;
        line-height: 1.75;
        font-weight: 500;
        color: var(--ink-soft);
    }

    /* Social links */
    .social-row {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5em;
        align-items: center;
    }

    .social-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        padding: 0.5em 1em;
        font-weight: 600;
        font-size: 1rem;
        color: var(--ink);
        text-decoration: none;
        border-radius: 100px;
        transition: background var(--transition), color var(--transition);
    }

    .social-link:hover {
        background: rgba(15, 20, 25, 0.06);
        text-decoration: none;
    }

    .social-link svg {
        opacity: 0.7;
        transition: opacity var(--transition);
    }

    .social-link:hover svg {
        opacity: 1;
    }

    /* CTAs */
    .cta {
        display: inline-block;
        padding: 0.75em 2em;
        font-weight: 700;
        font-size: 1.05rem;
        text-decoration: none;
        border-radius: 100px;
        transition:
            transform var(--transition),
            box-shadow var(--transition),
            background var(--transition),
            color var(--transition);
    }

    .cta:hover {
        text-decoration: none;
        transform: translateY(-1px);
    }

    .cta-primary {
        background: var(--ink);
        color: var(--surface);
        box-shadow: var(--shadow-md);
    }

    .cta-primary:hover {
        box-shadow: var(--shadow-hover);
        color: var(--surface);
    }

    .cta-secondary {
        background: transparent;
        color: var(--ink);
        border: 1px solid var(--border-hover);
    }

    .cta-secondary:hover {
        background: rgba(15, 20, 25, 0.04);
        border-color: rgba(15, 20, 25, 0.25);
    }

    /* Featured sections */
    .featured-section {
        padding-top: 1em;
    }

    .featured-heading {
        font-size: 0.85rem !important;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ink-muted);
        margin-bottom: 1.25em !important;
        text-align: center;
    }

    .featured-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5em;
    }

    .featured-link {
        display: block;
        padding: 0.85em 1.1em;
        text-decoration: none;
        border-radius: var(--radius);
        transition: background var(--transition);
    }

    .featured-link:hover {
        background: rgba(255, 255, 255, 0.55);
        text-decoration: none;
    }

    .featured-title {
        display: block;
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--ink);
        line-height: 1.4;
    }

    .featured-summary {
        display: block;
        font-size: 0.9rem;
        color: var(--ink-muted);
        line-height: 1.5;
        margin-top: 0.15em;
    }

    @media (max-width: 720px) {
        .hero {
            padding: 2em 1.5em;
        }

        .social-row {
            gap: 0.25em;
        }

        .social-link {
            padding: 0.4em 0.75em;
            font-size: 0.9rem;
        }
    }
</style>
