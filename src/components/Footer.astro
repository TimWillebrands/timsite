---
const today = new Date();
---

<footer>
	<span class="copyright">&copy; {today.getFullYear()} Tim Willebrands</span>
	<div class="social-links">
		<a href="https://www.linkedin.com/in/tim-willebrands-191b12a2" target="_blank" rel="noopener">LinkedIn</a>
		<a href="https://github.com/timwillebrands" target="_blank" rel="noopener">GitHub</a>
		<a href="https://bsky.app/profile/tim0theus.bsky.social" target="_blank" rel="noopener">Bluesky</a>
		<a href="mailto:mail@timwillebrands.nl">Email</a>
	</div>
</footer>
<style>
	footer {
		padding: 2.5em 1em 4em 1em;
		color: var(--ink-muted);
		text-align: center;
		font-size: 0.9em;
		border-top: 1px solid var(--border);
	}
	.copyright {
		display: block;
		margin-bottom: 0.75em;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1.5em;
	}
	.social-links a {
		text-decoration: none;
		color: var(--ink-muted);
		transition: color var(--transition);
	}
	.social-links a:hover {
		color: var(--ink);
		text-decoration: none;
	}
</style>
